    {
        "id": "e61f885c572fa701",
        "type": "function",
        "z": "ccf126f79d5fc349",
        "name": "build html",
        "func": "let rows = msg.payload;\n\nif (!rows || rows.length === 0) {\n    msg.payload = '<p style=\"padding:10px; color:#999;\">No data found. Click Find My Destinations.</p>';\n    return msg;\n}\n\nlet html = '<div style=\"font-family:Arial; padding:10px; overflow-x:auto;\"><table style=\"width:100%; border-collapse:collapse; min-width:400px;\"><thead><tr style=\"background:#1a73e8; color:white;\"><th style=\"padding:10px; text-align:left;\">#</th><th style=\"padding:10px; text-align:left;\">Region</th><th style=\"padding:10px; text-align:left;\">Score</th><th style=\"padding:10px; text-align:left;\">Cost/Night</th><th style=\"padding:10px; text-align:left;\">Airport</th><th style=\"padding:10px; text-align:left;\">Why visit?</th></tr></thead><tbody>';\n\nrows.forEach((row, i) => {\n    let bg = i % 2 === 0 ? '#f9f9f9' : 'white';\n    let score = parseFloat(row.score) || 0;\n    let scoreColor = score >= 80 ? '#27ae60' : score >= 60 ? '#f39c12' : '#e74c3c';\n    html += '<tr style=\"background:' + bg + ';\">';\n    html += '<td style=\"padding:10px;\">' + (i+1) + '</td>';\n    html += '<td style=\"padding:10px; font-weight:bold;\">' + (row.region || '') + '</td>';\n    html += '<td style=\"padding:10px; font-weight:bold; color:' + scoreColor + ';\">' + (row.score || '') + '/100</td>';\n    html += '<td style=\"padding:10px;\">\\u20ac' + (row.avg_cost_night || '') + '</td>';\n    html += '<td style=\"padding:10px;\">' + (row.airport || '') + ' (' + (row.airport_km || '') + 'km)</td>';\n    html += '<td style=\"padding:10px; color:#555; font-size:12px; max-width:200px;\">' + (row.motivation || '') + '</td>';\n    html += '</tr>';\n});\n\nhtml += '</tbody></table></div>';\n\nmsg.payload = html;\nreturn msg;",
