    {
        "id": "56e734873c0ed191",
        "type": "function",
        "z": "ccf126f79d5fc349",
        "name": "build profile",
        "func": "if (msg.topic === 'budget') {\n    flow.set('budget', msg.payload);\n}\nif (msg.topic === 'travel_month') {\n    flow.set('travel_month', msg.payload);\n}\nif (msg.topic === 'interests') {\n    flow.set('interests', msg.payload);\n}\nif (msg.topic === 'company') {\n    flow.set('company', msg.payload);\n    node.warn('company set to: ' + msg.payload);\n}\n\nif (msg.topic === 'submit') {\n    let profile = {\n        budget:        flow.get('budget')        || 'mid_range',\n        travel_months: [flow.get('travel_month') || 'june'],\n        days:          14,\n        interests:     [flow.get('interests')    || 'culture_history'],\n        company:       flow.get('company')       || 'solo',\n        mobility:      'public_transport'\n    };\n    node.warn('profile built: ' + JSON.stringify(profile));\n    msg.payload = JSON.stringify(profile, null, 2);\n    return msg;\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
