        "func": "let lines = msg.payload.trim().split('\\n');\nlet headers = lines[0].split(',');\nlet rows = [];\nfor (let i = 1; i < lines.length; i++) {\n    if (lines[i].trim() === '') continue;\n    let vals = lines[i].split(',');\n    let row = {};\n    headers.forEach((h, idx) => { row[h.trim()] = vals[idx] ? vals[idx].trim() : ''; });\n    rows.push(row);\n}\nlet html = '<div style=\"font-family:Arial; padding:10px; overflow-x:auto;\"><table style=\"width:100%; border-collapse:collapse;\">';\nhtml += '<thead><tr style=\"background:#1a73e8; color:white;\"><th style=\"padding:8px;\">Region</th><th style=\"padding:8px;\">Budget</th><th style=\"padding:8px;\">Avg/Night</th><th style=\"padding:8px;\">Cheap Meal</th><th style=\"padding:8px;\">Mid-Range Meal</th></tr></thead><tbody>';\nrows.forEach((row, i) => {\n    let bg = i % 2 === 0 ? '#f9f9f9' : 'white';\n    let bc = row.budget_level === 'backpacker' ? '#27ae60' : row.budget_level === 'mid_range' ? '#f39c12' : '#e74c3c';\n    html += '<tr style=\"background:' + bg + ';\">';\n    html += '<td style=\"padding:8px; font-weight:bold;\">' + (row.region || '') + '</td>';\n    html += '<td style=\"padding:8px; color:' + bc + '; font-weight:bold;\">' + (row.budget_level || '') + '</td>';\n    html += '<td style=\"padding:8px;\">€' + (row.avg_cost_night || '') + '</td>';\n    html += '<td style=\"padding:8px;\">' + (row.cheap_meal || 'n/a') + '</td>';\n    html += '<td style=\"padding:8px;\">' + (row.midrange_meal || 'n/a') + '</td>';\n    html += '</tr>';\n});\nhtml += '</tbody></table></div>';\nmsg.payload = html;\nreturn msg;",
